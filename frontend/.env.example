# Frontend Environment Variables (Vite)
# Copy this file to .env and fill in your values

# API Base URL (optional)
# If not set, it defaults to https://nglmessagemeweb.onrender.com in production
# and http://localhost:5000 in development
VITE_API_BASE_URL=https://nglmessagemeweb.onrender.com

# Alternative variable name (optional)
# VITE_API_URL=https://nglmessagemeweb.onrender.com

